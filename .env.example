# Gaggimate MCP Server Configuration

# Gaggimate Device Connection
GAGGIMATE_HOST=gaggimate.local
GAGGIMATE_PROTOCOL=ws

# Request Timeout (seconds)
GAGGIMATE_REQUEST_TIMEOUT=5.0

# Safety Limits
GAGGIMATE_MAX_TEMPERATURE=96.0
GAGGIMATE_MIN_TEMPERATURE=60.0
GAGGIMATE_MAX_PRESSURE=12.0
GAGGIMATE_MIN_PRESSURE=0.0

# Storage
GAGGIMATE_PROFILES_DIR=./profiles

# Agent Settings
GAGGIMATE_AI_PROFILE_SUFFIX= [AI]
GAGGIMATE_AI_NOTES_PREFIX=[Updated by AI]: 

# Logging
GAGGIMATE_LOG_LEVEL=INFO
GAGGIMATE_ENABLE_METRICS=true
